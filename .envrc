dotenv

ROOT_DIR="$(pwd)"
TF_VARS_FILE="${TF_VARS_FILE:-infra/prod.tfvars}"
TF_VARS_FILE_ABS="${ROOT_DIR}/${TF_VARS_FILE}"

export TF_VARS_FILE
export TF_CLI_ARGS_plan="-var-file=${TF_VARS_FILE_ABS}"
export TF_CLI_ARGS_apply="-var-file=${TF_VARS_FILE_ABS}"
export TF_CLI_ARGS_destroy="-var-file=${TF_VARS_FILE_ABS}"

if [ -n "${GCP_PROJECT_ID:-}" ] && [ -z "${PROJECT_ID:-}" ]; then
  export PROJECT_ID="${GCP_PROJECT_ID}"
fi

if command -v gh >/dev/null 2>&1; then
  GITHUB_TOKEN_FROM_GH="$(gh auth token 2>/dev/null || true)"
  if [ -n "${GITHUB_TOKEN_FROM_GH}" ]; then
    export GITHUB_TOKEN="${GITHUB_TOKEN_FROM_GH}"
  fi
fi
