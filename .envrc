dotenv

ROOT_DIR="$(pwd)"
TF_VARS_FILE="${TF_VARS_FILE:-infra/local.auto.tfvars}"
TF_VARS_FILE_ABS="${ROOT_DIR}/${TF_VARS_FILE}"
TF_BACKEND_CONFIG_FILE="${TF_BACKEND_CONFIG_FILE:-infra/backend.auto.hcl}"
TF_BACKEND_CONFIG_FILE_ABS="${ROOT_DIR}/${TF_BACKEND_CONFIG_FILE}"

TF_VARS_OUTPUT="${TF_VARS_FILE_ABS}" \
TF_BACKEND_CONFIG_OUTPUT="${TF_BACKEND_CONFIG_FILE_ABS}" \
  "${ROOT_DIR}/scripts/render-local-tf-config.sh"

export TF_VARS_FILE
export TF_BACKEND_CONFIG_FILE
export TF_CLI_ARGS_plan="-var-file=${TF_VARS_FILE_ABS}"
export TF_CLI_ARGS_apply="-var-file=${TF_VARS_FILE_ABS}"
export TF_CLI_ARGS_destroy="-var-file=${TF_VARS_FILE_ABS}"
export TF_CLI_ARGS_import="-var-file=${TF_VARS_FILE_ABS}"
export DRESS_TF_VAR_FILES="${TF_VARS_FILE_ABS}"
export DRESS_TF_BACKEND_CONFIG_FILES="${TF_BACKEND_CONFIG_FILE_ABS}"

if [ -n "${GCP_PROJECT_ID:-}" ] && [ -z "${PROJECT_ID:-}" ]; then
  export PROJECT_ID="${GCP_PROJECT_ID}"
fi

if command -v gh >/dev/null 2>&1; then
  GITHUB_TOKEN_FROM_GH="$(gh auth token 2>/dev/null || true)"
  if [ -n "${GITHUB_TOKEN_FROM_GH}" ]; then
    export GITHUB_TOKEN="${GITHUB_TOKEN_FROM_GH}"
  fi
fi
