dotenv

ROOT_DIR="$(pwd)"
TF_BACKEND_CONFIG_FILE="${TF_BACKEND_CONFIG_FILE:-infra/backend.auto.hcl}"
TF_BACKEND_CONFIG_FILE_ABS="${ROOT_DIR}/${TF_BACKEND_CONFIG_FILE}"

require_env() {
  local name="$1"
  if [ -z "${!name:-}" ]; then
    echo "Missing required environment variable: ${name}" >&2
    exit 1
  fi
}

for required_var in \
  GCP_OWNER \
  GCP_PROJECT_ID \
  GCP_PROJECT_NUMBER \
  GCP_REGION \
  GCS_BUCKET \
  GCP_REPOSITORY_ID \
  GCP_WORKLOAD_IDENTITY_POOL \
  GCP_WORKLOAD_IDENTITY_PROVIDER \
  GCP_SERVICE_NAME \
  GITHUB_OWNER \
  GITHUB_REPO; do
  require_env "${required_var}"
done

TF_BACKEND_CONFIG_OUTPUT="${TF_BACKEND_CONFIG_FILE_ABS}" \
  "${ROOT_DIR}/scripts/render-backend-config.sh"

export TF_BACKEND_CONFIG_FILE
export DRESS_TF_BACKEND_CONFIG_FILES="${TF_BACKEND_CONFIG_FILE_ABS}"
export TF_CLI_ARGS_init="-backend-config=${TF_BACKEND_CONFIG_FILE_ABS}"
export TF_VAR_gcp_owner="${GCP_OWNER}"
export TF_VAR_repository_id="${GCP_REPOSITORY_ID}"
export TF_VAR_project_id="${GCP_PROJECT_ID}"
export TF_VAR_project_number="${GCP_PROJECT_NUMBER}"
export TF_VAR_region="${GCP_REGION}"
export TF_VAR_pool_id="${GCP_WORKLOAD_IDENTITY_POOL}"
export TF_VAR_provider_id="${GCP_WORKLOAD_IDENTITY_PROVIDER}"
export TF_VAR_service_name="${GCP_SERVICE_NAME}"
export TF_VAR_container_port="${CONTAINER_PORT:-8080}"
export TF_VAR_github_owner="${GITHUB_OWNER}"
export TF_VAR_github_repo="${GITHUB_REPO}"
export TF_VAR_cloud_run_image_tag="${CLOUD_RUN_IMAGE_TAG:-latest}"

if [ -n "${GCP_PROJECT_ID:-}" ] && [ -z "${PROJECT_ID:-}" ]; then
  export PROJECT_ID="${GCP_PROJECT_ID}"
fi

if command -v gh >/dev/null 2>&1; then
  GITHUB_TOKEN_FROM_GH="$(gh auth token 2>/dev/null || true)"
  if [ -n "${GITHUB_TOKEN_FROM_GH}" ]; then
    export GITHUB_TOKEN="${GITHUB_TOKEN_FROM_GH}"
  fi
fi
