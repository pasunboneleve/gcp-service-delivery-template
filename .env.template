# ===================================================================
# Local Environment (.env)
# ===================================================================
# Keep the canonical local deployment configuration here. `.envrc`
# exports Terraform inputs via `TF_VAR_*` and renders backend config
# from these values.

GCP_OWNER=owner@example.com

# Used by scripts/bootstrap-tf-state.sh and tofu init.
GCP_PROJECT_ID=example-gcp-project-id
GCP_PROJECT_NUMBER=123456789012
GCP_REGION=example-gcp-region
GCS_BUCKET=example-gcp-tf-state-bucket
GCP_REPOSITORY_ID=example-artifact-registry-repo
GCP_WORKLOAD_IDENTITY_POOL=example-github-pool
GCP_WORKLOAD_IDENTITY_PROVIDER=example-github-provider
GCP_SERVICE_NAME=example-cloud-run-service
CONTAINER_PORT=8080
CLOUD_RUN_IMAGE_TAG=latest
GITHUB_OWNER=example-github-owner
GITHUB_REPO=example-github-repo

# direnv writes generated backend config to this file by default.
TF_BACKEND_CONFIG_FILE=infra/backend.auto.hcl

# Optional manual fallback for Terraform's GitHub provider.
# If GitHub CLI authentication is available, .envrc refreshes
# GITHUB_TOKEN from `gh auth token` whenever direnv allow/reload/refresh
# runs and that refreshed token takes precedence over this value.
GITHUB_TOKEN=
